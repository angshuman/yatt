{
  "name": "yatt-md",
  "version": "0.1.1",
  "description": "Yet Another Task Tracker — plain-text Markdown task tracking with Gantt, Kanban, and git integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yatt": "dist/cli/serve.js"
  },
  "files": [
    "dist/",
    "README.md",
    "SPEC.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "task-tracker",
    "gantt",
    "kanban",
    "markdown",
    "plaintext",
    "git",
    "project-management",
    "cli"
  ],
  "homepage": "https://github.com/angshuman/yatt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angshuman/yatt.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && esbuild cli/serve.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/cli/serve.js \"--banner:js=#!/usr/bin/env node\"",
    "start": "node dist/cli/serve.js .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build && esbuild src/index.ts --bundle --format=iife --global-name=YattLib --outfile=site/yatt.bundle.js --platform=browser --minify"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.4.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
