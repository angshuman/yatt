{
  "name": "yatt",
  "version": "0.1.0",
  "description": "Yet Another Task Tracker — plain-text Gantt charts in Markdown",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yatt": "./dist/cli/serve.js"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "build:site": "esbuild src/index.ts --bundle --format=iife --global-name=YattLib --outfile=site/yatt.bundle.js --platform=browser --minify",
    "build:cli": "esbuild cli/serve.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/cli/serve.js \"--banner:js=#!/usr/bin/env node\"",
    "build:all": "npm run build && npm run build:site && npm run build:cli",
    "dev": "tsc --watch",
    "dev:cli": "npm run build:cli -- --watch",
    "serve": "node dist/cli/serve.js .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build:all"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.4.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
